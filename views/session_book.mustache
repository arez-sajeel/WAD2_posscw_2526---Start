{{> head}}
{{> header}}

<article class="wrap course-detail">
  <header class="course-detail__header">
    <p class="eyebrow">Session booking</p>
    <h1>Book Session</h1>
    <p class="course-description">{{course.title}}</p>
    <p class="course-dates">{{session.start}} to {{session.end}}</p>
  </header>

  <section class="course-section" aria-labelledby="session-summary-heading">
    <h2 id="session-summary-heading">Session summary</h2>
    <dl class="kv">
      <dt>Capacity</dt><dd>{{session.capacity}}</dd>
      <dt>Remaining places</dt><dd>{{session.remaining}}</dd>
    </dl>
  </section>

  <section class="course-section" aria-labelledby="session-action-heading">
    <h2 id="session-action-heading">Confirm booking</h2>
    {{#user}}
    <form method="post" action="/sessions/{{session.id}}/book" class="course-booking-form">
      <button class="btn primary" type="submit">Confirm Session Booking</button>
    </form>
    {{/user}}
    {{^user}}
    <p class="muted">Sign in to confirm this session booking.</p>
    <a class="btn primary" href="/auth/login">Log in to continue</a>
    {{/user}}
  </section>
</article>

{{> footer}}