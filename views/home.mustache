{{> head}}
{{> header}}

<section class="wrap home-hero">
  <p class="eyebrow">Weekly classes and special workshops</p>
  <h1>Upcoming Courses</h1>
  <p class="lead">
    Explore the next yoga blocks and workshops, compare schedules at a glance,
    and move straight to the course information you need.
  </p>
  <div class="actions">
    <a class="btn primary" href="/courses">Browse all courses</a>
  </div>
</section>

{{#hasBookedCourses}}
<section class="wrap" aria-labelledby="home-booked-courses-heading">
  <div class="section-header">
    <div>
      <p class="eyebrow">Your practice</p>
      <h2 id="home-booked-courses-heading">Your booked courses</h2>
    </div>
  </div>

  <div class="cards">
    {{#bookedCourses}}
    <article class="card">
      <div class="card-copy">
        <div class="card-heading">
          <div>
            <p class="eyebrow">{{level}}</p>
            <h2>{{title}}</h2>
          </div>
          {{#booking}}
          <p class="status-pill {{statusClass}}">{{statusLabel}}</p>
          {{/booking}}
        </div>
        <p class="card-meta">
          <span>{{type}}</span>
          {{#allowDropIn}}<span>Drop-in available</span>{{/allowDropIn}}
        </p>
        <p>{{description}}</p>
        <p class="muted">Duration: {{duration}}</p>
        <p class="muted">Dates: {{startDate}} to {{endDate}}</p>
        <p class="muted">Time: {{time}}</p>
        {{#locationName}}<p class="muted">Location: {{locationName}}</p>{{/locationName}}
        {{#hasPrice}}<p class="muted">Price: £{{price}}</p>{{/hasPrice}}
        <p class="muted">Next session: {{nextSession}}</p>
        <p class="muted">Sessions: {{sessionsCount}}</p>
        {{#booking}}<p class="muted booking-note">{{message}}</p>{{/booking}}
      </div>
      <div class="card-actions">
        {{#booking}}
        <a class="btn primary" href="{{manageHref}}">Manage booking</a>
        {{/booking}}
        <a class="btn" href="/courses/{{id}}">View course</a>
      </div>
    </article>
    {{/bookedCourses}}
  </div>
</section>
{{/hasBookedCourses}}

<section class="wrap">
  <div class="section-header">
    <div>
      {{#hasBookedCourses}}<p class="eyebrow">More to explore</p>{{/hasBookedCourses}}
      {{^hasBookedCourses}}<p class="eyebrow">Now booking</p>{{/hasBookedCourses}}
      <h2>Featured courses</h2>
    </div>
  </div>

  <div class="cards">
    {{#featuredCourses}}
    <article class="card">
      <div class="card-copy">
        <p class="eyebrow">{{level}}</p>
        <h2>{{title}}</h2>
        <p class="card-meta">
          <span>{{type}}</span>
          {{#allowDropIn}}<span>Drop-in available</span>{{/allowDropIn}}
        </p>
        <p>{{description}}</p>
        <p class="muted">Duration: {{duration}}</p>
        <p class="muted">Dates: {{startDate}} to {{endDate}}</p>
        <p class="muted">Time: {{time}}</p>
        {{#locationName}}<p class="muted">Location: {{locationName}}</p>{{/locationName}}
        {{#hasPrice}}<p class="muted">Price: £{{price}}</p>{{/hasPrice}}
        <p class="muted">Next session: {{nextSession}}</p>
        <p class="muted">Sessions: {{sessionsCount}}</p>
      </div>
      <div class="card-actions">
        <a class="btn primary" href="/courses/{{id}}">View details</a>
        <a class="btn" href="/courses">See all courses</a>
      </div>
    </article>
    {{/featuredCourses}}

    {{^hasFeaturedCourses}}
    <article class="card empty-state">
      <h2>No additional courses available right now</h2>
      <p class="muted">Your active bookings are up to date. Check back soon for newly scheduled classes and workshops.</p>
    </article>
    {{/hasFeaturedCourses}}
  </div>
</section>

{{> footer}}
