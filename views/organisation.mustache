{{> head}}
{{> header}}

<section class="wrap content-stack">
  <article class="card org-intro">
    <div class="card-copy">
      <p class="eyebrow">About us</p>
      <h1>Our Organisation</h1>
      <p class="lead">
        We are a community-focused yoga studio in Edinburgh, offering weekly
        classes, weekend workshops, and drop-in sessions for all levels.
      </p>
      <p>
        Founded in 2020, our mission is to make yoga accessible to everyone.
        Whether you are a complete beginner or an experienced practitioner, our
        qualified instructors will guide you through safe, supportive sessions
        tailored to your needs.
      </p>
    </div>
  </article>

  <div class="cards org-grid">
    <section class="card" aria-labelledby="org-what-heading">
      <div class="card-copy">
        <h2 id="org-what-heading">What we offer</h2>
        <ul class="feature-list">
          <li><strong>Weekly blocks</strong> — structured 12-week programmes that build progressively.</li>
          <li><strong>Weekend workshops</strong> — intensive one- or two-day sessions on focused topics.</li>
          <li><strong>Drop-in classes</strong> — pay-as-you-go sessions on eligible courses.</li>
        </ul>
      </div>
    </section>

    <section class="card org-contact" aria-labelledby="org-contact-heading">
      <div class="card-copy">
        <h2 id="org-contact-heading">Contact</h2>
        <dl class="kv">
          <dt>Email</dt><dd>hello@yogastudio.local</dd>
          <dt>Phone</dt><dd>0131 555 0123</dd>
          <dt>Address</dt><dd>12 Harmony Lane, Edinburgh EH1 2AB</dd>
        </dl>
      </div>
    </section>
  </div>

  <div class="actions section-actions">
    <a class="btn primary" href="/courses">Browse courses</a>
    <a class="btn" href="/locations">Our locations</a>
  </div>
</section>

{{> footer}}
