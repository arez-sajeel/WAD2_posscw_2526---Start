
{{> head}}
{{> header}}

<div class="wrap">
  <h1>{{ title }}</h1>

  {{#errors}}
  <div class="alert error" role="alert" aria-live="assertive">
    <ul>
      {{#list}}
      <li>{{ . }}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  <form method="post" action="/auth/register" class="auth-form">
    <div class="field">
      <label for="name">Full name</label>
      <input id="name" name="name" type="text" required autocomplete="name" value="{{ values.name }}" {{#fieldErrors.name}}aria-describedby="name-error" aria-invalid="true"{{/fieldErrors.name}}>
      {{#fieldErrors.name}}
      <p id="name-error" class="field-error" role="alert">{{ fieldErrors.name }}</p>
      {{/fieldErrors.name}}
    </div>

    <div class="field">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required autocomplete="email" value="{{ values.email }}" {{#fieldErrors.email}}aria-describedby="email-error" aria-invalid="true"{{/fieldErrors.email}}>
      {{#fieldErrors.email}}
      <p id="email-error" class="field-error" role="alert">{{ fieldErrors.email }}</p>
      {{/fieldErrors.email}}
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required autocomplete="new-password" minlength="8" {{#fieldErrors.password}}aria-describedby="password-error" aria-invalid="true"{{/fieldErrors.password}}>
      <span class="hint">Minimum 8 characters.</span>
      {{#fieldErrors.password}}
      <p id="password-error" class="field-error" role="alert">{{ fieldErrors.password }}</p>
      {{/fieldErrors.password}}
    </div>

    <div class="actions">
      <button type="submit" class="btn">Create account</button>
    </div>
  </form>

  <p class="muted">Already have an account? <a href="/auth/login">Log in here</a>.</p>
</div>

{{> footer}}
