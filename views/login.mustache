
{{> head}}
{{> header}}

<div class="wrap">
  <h1>{{ title }}</h1>

  {{#error}}
  <div class="alert error" role="alert" aria-live="assertive">
    <p>{{ error }}</p>
  </div>
  {{/error}}

  <form method="post" action="/auth/login" class="auth-form">
    <div class="field">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required autocomplete="email" value="{{ values.email }}" {{#fieldErrors.email}}aria-describedby="email-error" aria-invalid="true"{{/fieldErrors.email}}>
      {{#fieldErrors.email}}
      <p id="email-error" class="field-error" role="alert">{{ fieldErrors.email }}</p>
      {{/fieldErrors.email}}
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required autocomplete="current-password" {{#fieldErrors.password}}aria-describedby="password-error" aria-invalid="true"{{/fieldErrors.password}}>
      {{#fieldErrors.password}}
      <p id="password-error" class="field-error" role="alert">{{ fieldErrors.password }}</p>
      {{/fieldErrors.password}}
    </div>

    <div class="actions">
      <button type="submit" class="btn">Log in</button>
    </div>
  </form>

  <p class="muted">Don't have an account? <a href="/auth/register">Register here</a>.</p>
</div>

{{> footer}}
